# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL from: supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon (public) key — safe to expose in browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — SERVER SIDE ONLY, never expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App ──────────────────────────────────────────────────────────────────────
# Full URL of your app (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Root domain for multi-tenant subdomain routing (e.g. yourapp.com)
NEXT_PUBLIC_ROOT_DOMAIN=yourcrm.com

# ─── Platform admin ───────────────────────────────────────────────────────────
# A long random string for server-side platform admin operations
# Generate with: openssl rand -hex 32
PLATFORM_ADMIN_SECRET=change-me-to-a-long-random-string

# ─── Email system ─────────────────────────────────────────────────────────────
# Provider selection: "resend" (default) or "ses"
EMAIL_PROVIDER=resend

# ── Sender identity ────────────────────────────────────────────────────────────
# Use RESEND_FROM_EMAIL or EMAIL_FROM_ADDRESS (either name works)
# Value can be bare email OR formatted: "Nexora <noreply@yourdomain.com>"
# IMPORTANT: this domain/address must be verified in your Resend account.
# Add and verify at: https://resend.com/domains
RESEND_FROM_EMAIL=noreply@yourdomain.com
RESEND_FROM_NAME=Nexora
RESEND_REPLY_TO=support@yourdomain.com

# Aliases (same meaning — use whichever you prefer):
# EMAIL_FROM_ADDRESS=noreply@yourdomain.com
# EMAIL_FROM_NAME=Nexora
# EMAIL_REPLY_TO=support@yourdomain.com

# Feature flags
EMAIL_TRANSACTIONAL_ENABLED=true
EMAIL_MARKETING_ENABLED=false

# Logging verbosity: silent | error | info | debug
EMAIL_LOG_LEVEL=info

# ── Resend (used when EMAIL_PROVIDER=resend) ───────────────────────────────────
# Get your key from: resend.com → API Keys
# Keys always start with "re_"
RESEND_API_KEY=re_...

# ── Amazon SES v2 (used when EMAIL_PROVIDER=ses) ──────────────────────────────
# Required when EMAIL_PROVIDER=ses
AWS_SES_REGION=us-east-1
AWS_SES_ACCESS_KEY_ID=AKIA...
AWS_SES_SECRET_ACCESS_KEY=your-secret-access-key

# Optional SES settings
AWS_SES_CONFIGURATION_SET=
AWS_SES_FROM_ARN=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Connect (OAuth) client ID — starts with ca_
# Get from: dashboard.stripe.com → Connect → Settings
STRIPE_CLIENT_ID=ca_...

# ─── Square ───────────────────────────────────────────────────────────────────
# Get from: developer.squareup.com → My Applications → OAuth
SQUARE_APPLICATION_ID=sq0idp-...
SQUARE_APPLICATION_SECRET=sq0csp-...

# ─── OAuth CSRF ───────────────────────────────────────────────────────────────
# Random secret for signing OAuth state tokens (prevents CSRF)
# Generate with: openssl rand -hex 32
OAUTH_STATE_SECRET=your-random-hex-secret-here

# ─── Vercel (custom domain integration) ──────────────────────────────────────
# Create a token at: vercel.com/account/tokens
VERCEL_TOKEN=your-vercel-api-token

# Project ID from: Vercel Dashboard → your project → Settings → General
VERCEL_PROJECT_ID=prj_...

# Team ID (only required for team/org projects)
VERCEL_TEAM_ID=

# ─── 360 Spin Package Module ──────────────────────────────────────────────────
# ImagineAPI token (Midjourney REST proxy) — https://www.imagineapi.dev
# Required for AI image generation. Get yours at imagineapi.dev after subscribing.
IMAGINE_API_TOKEN=your-imagineapi-token-here

# NOTE: You must also create a public Supabase Storage bucket named "spin-images"
# in your Supabase project → Storage → Create Bucket (set to Public)

# ─── AI Website Builder — Image Generation ────────────────────────────────────
# Google AI / Gemini API key. Used for TWO features:
#   1. Website text autofill (Gemini model — DO NOT change that model config)
#   2. Website image generation (Imagen 4 Ultra model — see WEBSITE_IMAGE_MODEL below)
#
# Get your key at: aistudio.google.com → API Keys
# The SAME key works for both Gemini text and Imagen image generation.
GEMINI_API_KEY=your-google-ai-api-key-here

# Imagen model used for AI website image generation.
# Default (and required value): imagen-4.0-ultra-generate-001
# Only override this if Google releases a newer model and you want to test it.
# DO NOT set this to a Gemini text model — it is only for Imagen image generation.
WEBSITE_IMAGE_MODEL=imagen-4.0-ultra-generate-001

# Optional: set to "1" or "true" to disable AI image generation entirely
# (e.g. while API key is being provisioned). Website text autofill still works.
# WEBSITE_AI_IMAGES_DISABLED=

# Supabase Storage bucket for AI-generated website images.
# Default: website-assets (created automatically by migration 054)
# Only override if you want to use a different existing bucket.
# WEBSITE_IMAGE_BUCKET=website-assets

# ─── Supabase Storage buckets required ────────────────────────────────────────
# The following buckets are created automatically by running migrations:
#   website-assets  → migration 054_website_image_plans_complete.sql
#   website-images  → migration 054_website_image_plans_complete.sql
#   spin-images     → create manually in Supabase Dashboard → Storage
