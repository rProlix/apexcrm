# AWS credentials must come from the EC2 instance profile, not this file.
AWS_REGION=us-west-2
SQS_QUEUE_URL=https://sqs.us-west-2.amazonaws.com/123456789012/van-damage
S3_BUCKET=nexoranow-van-damage-production

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-with-supabase-service-role-key

GOOGLE_GEMINI_API_KEY=replace-with-google-gemini-api-key
SLACK_TOKEN_ENCRYPTION_KEY=replace-with-the-existing-32-byte-or-base64-key

LOG_LEVEL=info
NODE_ENV=production
